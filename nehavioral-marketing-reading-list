<style>
  :root {
    --void: #0D0D0D;
    --void-soft: #1A1A1A;
    --void-mid: #252525;
    --signal: #C8F04A;
    --signal-dim: #A8CC3A;
    --text: #F5F2ED;
    --text-muted: #8A8478;
    --text-dim: #5C5850;
    --rule: rgba(245,242,237,0.1);
    --rule-strong: rgba(245,242,237,0.2);
    --b: #4A9EFF;
    --e: #FF6B6B;
    --a: #FFB347;
    --m: #A78BFA;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }
  body {
    background: var(--void);
    color: var(--text);
    font-family: 'Inter', sans-serif;
    -webkit-font-smoothing: antialiased;
    line-height: 1.7;
  }
  .wrap { max-width: 1080px; margin: 0 auto; padding: 0 28px; }
  a { color: inherit; }

  /* NAV */
  nav {
    border-bottom: 1px solid var(--rule);
    padding: 20px 0;
    position: sticky; top: 0; z-index: 50;
    background: rgba(13,13,13,0.96);
    backdrop-filter: blur(12px);
  }
  .nav-inner {
    display: flex; align-items: center; justify-content: space-between; gap: 24px;
  }
  .nav-mark {
    font-family: 'DM Mono', monospace;
    font-size: 13px; letter-spacing: 0.12em; text-transform: uppercase;
    color: var(--text-muted); text-decoration: none;
  }
  .nav-mark strong { color: var(--signal); font-weight: 500; }
  .nav-links {
    display: flex; gap: 22px;
    font-family: 'DM Mono', monospace;
    font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--text-muted);
  }
  .nav-links a { text-decoration: none; transition: color 0.15s; }
  .nav-links a:hover { color: var(--signal); }

  /* HERO */
  .hero {
    padding: 88px 0 72px;
    border-bottom: 1px solid var(--rule);
  }
  .hero-label {
    font-family: 'DM Mono', monospace;
    font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--text-dim);
    margin-bottom: 26px;
    display: flex; align-items: center; gap: 12px;
  }
  .hero-label::before {
    content: "";
    display: inline-block;
    width: 24px; height: 1px;
    background: var(--text-dim);
  }
  h1 {
    font-family: 'DM Serif Display', serif;
    font-size: clamp(46px, 7vw, 78px);
    line-height: 1; letter-spacing: -0.02em;
    max-width: 14ch; margin-bottom: 28px;
  }
  h1 em { color: var(--signal); font-style: italic; }
  .dek {
    font-size: 18px; line-height: 1.65;
    color: var(--text-muted); max-width: 58ch;
  }
  .dek strong { color: var(--text); font-weight: 500; }

  /* LAYOUT */
  .reading-shell {
    display: grid;
    grid-template-columns: 220px minmax(0, 720px);
    gap: 72px;
    padding: 72px 0 96px;
  }
  .aside { position: sticky; top: 104px; align-self: start; }
  .aside-label {
    font-family: 'DM Mono', monospace;
    font-size: 9px; letter-spacing: 0.12em; text-transform: uppercase;
    color: var(--text-dim); margin-bottom: 12px;
  }
  .aside p { font-size: 13px; color: var(--text-muted); margin-bottom: 24px; }
  .toc { list-style: none; border-top: 1px solid var(--rule-strong); }
  .toc a {
    display: block; padding: 10px 0;
    border-bottom: 1px solid var(--rule);
    font-family: 'DM Mono', monospace;
    font-size: 11px; letter-spacing: 0.06em; text-transform: uppercase;
    color: var(--text-muted); text-decoration: none;
    transition: color 0.15s;
  }
  .toc a:hover { color: var(--signal); }

  /* SECTION */
  .reading-section {
    margin-bottom: 72px;
    scroll-margin-top: 100px;
  }
  .reading-section:last-child { margin-bottom: 0; }
  .section-label {
    font-family: 'DM Mono', monospace;
    font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--text-dim);
    padding-bottom: 16px;
    border-bottom: 1px solid var(--rule-strong);
    margin-bottom: 32px;
    display: flex; align-items: center; gap: 10px;
  }
  .section-label::before {
    content: "";
    display: inline-block; width: 1px; height: 16px;
    background: var(--text-dim);
  }

  /* HIGHLIGHTED BOOK */
  .book-featured {
    background: var(--void-soft);
    border: 1px solid var(--rule-strong);
    border-left: 3px solid var(--signal);
    padding: 28px;
    margin-bottom: 1px;
  }
  .book-featured-tag {
    font-family: 'DM Mono', monospace;
    font-size: 9px; letter-spacing: 0.12em; text-transform: uppercase;
    color: var(--signal);
    margin-bottom: 14px;
    display: block;
  }
  .book-title {
    font-family: 'DM Serif Display', serif;
    font-size: 22px; line-height: 1.15;
    margin-bottom: 4px;
    color: var(--text);
  }
  .book-author {
    font-family: 'DM Mono', monospace;
    font-size: 10px; letter-spacing: 0.08em; text-transform: uppercase;
    color: var(--text-dim);
    margin-bottom: 14px;
    display: block;
  }
  .book-blurb {
    font-size: 14px; line-height: 1.7;
    color: var(--text-muted);
  }

  /* REGULAR BOOK LIST */
  .book-list {
    border: 1px solid var(--rule-strong);
    border-top: none;
  }
  .book-item {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 16px;
    padding: 18px 20px;
    border-top: 1px solid var(--rule);
    align-items: start;
  }
  .book-item-title {
    font-family: 'DM Serif Display', serif;
    font-size: 18px; line-height: 1.2;
    color: var(--text);
    margin-bottom: 3px;
  }
  .book-item-author {
    font-family: 'DM Mono', monospace;
    font-size: 9px; letter-spacing: 0.08em; text-transform: uppercase;
    color: var(--text-dim);
  }

  /* CTA */
  .reading-cta {
    padding: 48px;
    background: var(--void-soft);
    border-top: 3px solid var(--signal);
    margin-top: 64px;
  }
  .reading-cta h2 {
    font-family: 'DM Serif Display', serif;
    font-size: 30px; margin-bottom: 12px;
  }
  .reading-cta p {
    font-size: 15px; color: var(--text-muted);
    max-width: 55ch; margin-bottom: 24px;
  }
  .btn {
    display: inline-flex; align-items: center; gap: 10px;
    font-family: 'DM Mono', monospace;
    font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase;
    padding: 14px 20px;
    border: 1.5px solid var(--signal);
    background: var(--signal); color: var(--void);
    text-decoration: none;
    transition: background 0.15s, border-color 0.15s;
  }
  .btn:hover { background: var(--signal-dim); border-color: var(--signal-dim); }
  .btn.secondary { background: transparent; color: var(--signal); }
  .btn.secondary:hover { background: var(--signal); color: var(--void); }

  /* RELATED */
  .related {
    padding: 72px 0;
    border-top: 1px solid var(--rule);
    background: var(--void-soft);
  }
  .related h2 { font-family: 'DM Serif Display', serif; font-size: 36px; margin-bottom: 28px; }
  .related-grid {
    display: grid; grid-template-columns: repeat(3, 1fr);
    gap: 1px; background: var(--rule-strong);
    border: 1px solid var(--rule-strong);
  }
  .related-card {
    padding: 28px; background: var(--void);
    text-decoration: none; transition: background 0.15s;
  }
  .related-card:hover { background: var(--void-mid); }
  .related-tag {
    font-family: 'DM Mono', monospace;
    font-size: 9px; letter-spacing: 0.12em; text-transform: uppercase;
    color: var(--text-dim);
  }
  .related-card h3 {
    font-family: 'DM Serif Display', serif;
    font-size: 22px; margin: 12px 0 8px; color: var(--text);
    transition: color 0.15s;
  }
  .related-card:hover h3 { color: var(--signal); }
  .related-card p { font-size: 13px; color: var(--text-muted); }

  /* FOOTER */
  footer { padding: 30px 0; border-top: 1px solid var(--rule); }
  .foot-inner {
    display: flex; justify-content: space-between; align-items: center;
    flex-wrap: wrap; gap: 16px;
  }
  .foot-copy {
    font-family: 'DM Mono', monospace;
    font-size: 10px; letter-spacing: 0.06em; text-transform: uppercase;
    color: var(--text-dim);
  }
  .foot-link {
    font-family: 'DM Mono', monospace;
    font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase;
    color: var(--text-muted); text-decoration: none; transition: color 0.15s;
  }
  .foot-link:hover { color: var(--signal); }

  /* RESPONSIVE */
  @media (max-width: 800px) {
    .reading-shell { grid-template-columns: 1fr; gap: 36px; }
    .aside { position: static; }
    .toc { display: grid; grid-template-columns: repeat(2, 1fr); }
    .related-grid { grid-template-columns: 1fr; }
    .nav-links { display: none; }
  }
  @media (max-width: 560px) {
    .hero { padding: 64px 0 52px; }
    h1 { font-size: 44px; }
    .reading-shell { padding: 52px 0 72px; }
    .toc { grid-template-columns: 1fr; }
    .reading-cta { padding: 32px 24px; }
    .book-item { grid-template-columns: 1fr; }
  }
  @media (prefers-reduced-motion: reduce) { * { transition: none !important; } }
